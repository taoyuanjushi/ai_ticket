            },
            "url": "{{javaBaseUrl}}/tickets/{{TOM_TICKET_ID}}/ai-replies"
          }
        },
        {
          "name": "Java - user cannot save AI reply",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
