            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"tom\",\n  \"conversation_id\": \"chat-user-query-001\",\n  \"message\": \"查一下所有处理中工单\",\n  \"auth_token\": \"{{USER_TOKEN}}\"\n}"
            },
            "url": "{{pythonBaseUrl}}/agent/chat"
          }
        },
        {
          "name": "Python - create ticket pending_action",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"tom\",\n  \"conversation_id\": \"chat-create-001\",\n  \"message\": \"帮我创建一个工单，标题是支付失败，描述是用户支付成功但订单仍显示未支付，优先级高\",\n  \"auth_token\": \"{{USER_TOKEN}}\"\n}"
            },
            "url": "{{pythonBaseUrl}}/agent/chat"
          }
        },
        {
          "name": "Python - confirm create ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.answer) {",
                  "  const match = json.answer.match(/ID\\s*(\\d+)/);",
                  "  if (match) pm.environment.set('AI_CREATED_TICKET_ID', match[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"tom\",\n  \"conversation_id\": \"chat-create-001\",\n  \"message\": \"确认\",\n  \"auth_token\": \"{{USER_TOKEN}}\"\n}"
            },
            "url": "{{pythonBaseUrl}}/agent/chat"
          }
        },
        {
          "name": "Python - confirm again should not duplicate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"tom\",\n  \"conversation_id\": \"chat-create-001\",\n  \"message\": \"确认\",\n  \"auth_token\": \"{{USER_TOKEN}}\"\n}"
            },
            "url": "{{pythonBaseUrl}}/agent/chat"
          }
        },
        {
          "name": "Python - update status pending_action",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"staff\",\n  \"conversation_id\": \"chat-update-001\",\n  \"message\": \"把 {{TOM_TICKET_ID}} 号工单改成处理中\",\n  \"auth_token\": \"{{STAFF_TOKEN}}\"\n}"
            },
            "url": "{{pythonBaseUrl}}/agent/chat"
          }
        },
        {
          "name": "Python - confirm update status",
          "request": {
            "method": "POST",
            "header": [
