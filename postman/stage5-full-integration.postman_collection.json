    {
      "name": "02 Java Tickets",
      "item": [
        {
          "name": "Java - tom creates ticket -> TOM_TICKET_ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.environment.set('TOM_TICKET_ID', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"登录失败\",\n  \"content\": \"账号无法登录，重置密码后仍然失败\",\n  \"priority\": \"HIGH\",\n  \"category\": \"ACCOUNT\"\n}"
            },
            "url": "{{javaBaseUrl}}/tickets"
          }
        },
        {
          "name": "Java - tom query own tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": "{{javaBaseUrl}}/tickets?page=1&size=10"
          }
        },
        {
          "name": "Java - staff query all tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{STAFF_TOKEN}}"
              }
            ],
            "url": "{{javaBaseUrl}}/tickets?page=1&size=10"
          }
        },
        {
          "name": "Java - staff update status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{STAFF_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\"\n}"
            },
            "url": "{{javaBaseUrl}}/tickets/{{TOM_TICKET_ID}}/status"
          }
        },
        {
          "name": "Java - ticket full detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{STAFF_TOKEN}}"
              }
