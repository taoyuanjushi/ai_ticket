# Copy this file to .env before running Docker Compose.
# Do not commit real passwords, tokens, or API keys.

DB_NAME=springboot_demo
DB_USERNAME=root
DB_PASSWORD=change_me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0

JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_bytes
JWT_EXPIRATION=86400000

AI_SERVICE_BASE_URL=http://python-ai:8001
JAVA_API_BASE_URL=http://java-backend:8080
JAVA_API_TIMEOUT=10
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl

LLM_MOCK_MODE=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT=30
LLM_TIMEOUT_SECONDS=30

VITE_API_BASE_URL=/api
FRONTEND_PORT=8088
